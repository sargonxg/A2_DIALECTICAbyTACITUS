# DIALECTICA Cloud Run cost-saver environment
# Copy to a private env file or use these values in Cloud Run.
# Do not put secret values in this file.

GCP_PROJECT_ID=praxisbytacitus
GCP_REGION=us-central1
SERVICE_NAME=dialectica-api
ARTIFACT_REPOSITORY=dialectica

ENVIRONMENT=production
GRAPH_BACKEND=neo4j
NEO4J_CONNECTION_TIMEOUT=5
DATABASE_URL=postgresql+asyncpg://dialectica:PASSWORD@/dialectica?host=/cloudsql/PROJECT:REGION:INSTANCE
CLOUD_SQL_CONNECTION_NAME=PROJECT:REGION:INSTANCE
CORS_ORIGINS=*
RATE_LIMIT_BACKEND=memory
LOG_LEVEL=INFO

GRAPHITI_USE_NATIVE=false
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

COZO_USE_EMBEDDED=true
COZO_ENGINE=mem
COZO_PATH=
COZO_OPTIONS={}
COZO_SNAPSHOT_PATH=
COZO_GCS_BUCKET=
GRAPH_REASONING_CHUNK_CHARS=6000

# Secret Manager secret names expected by infrastructure/scripts/deploy-cloudrun.sh
NEO4J_URI_SECRET=dialectica-neo4j-uri
NEO4J_USER_SECRET=dialectica-neo4j-user
NEO4J_USERNAME_SECRET=dialectica-neo4j-username
NEO4J_PASSWORD_SECRET=dialectica-neo4j-password
NEO4J_DATABASE_SECRET=dialectica-neo4j-database
GEMINI_API_KEY_SECRET=dialectica-gemini-api-key
AURA_INSTANCEID_SECRET=dialectica-aura-instanceid
AURA_INSTANCENAME_SECRET=dialectica-aura-instancename
ADMIN_API_KEY_SECRET=dialectica-admin-key
DATABASE_URL_SECRET=dialectica-database-url

# Cost controls
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=1
CLOUD_RUN_CPU=1
CLOUD_RUN_MEMORY=1Gi
CLOUD_RUN_CONCURRENCY=40
