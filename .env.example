# ═══════════════════════════════════════════════════════════════════════════
# DIALECTICA by TACITUS — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Google Cloud Platform ──────────────────────────────────────────────────

# Your GCP project ID (required)
GCP_PROJECT_ID=your-gcp-project-id

# Path to GCP service account key file (for local development)
# In Cloud Run, use Workload Identity instead
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ─── Google Cloud Spanner ───────────────────────────────────────────────────

# Spanner instance ID (default: dialectica-graph)
SPANNER_INSTANCE_ID=dialectica-graph

# Spanner database ID (default: dialectica)
SPANNER_DATABASE_ID=dialectica

# For local development with Spanner emulator:
# SPANNER_EMULATOR_HOST=localhost:9010
# Uncomment above and leave GCP credentials empty for emulator mode

# ─── Vertex AI ──────────────────────────────────────────────────────────────

# Vertex AI region (us-east1 recommended for TACITUS workloads)
VERTEX_AI_LOCATION=us-east1

# Gemini model IDs
GEMINI_FLASH_MODEL=gemini-2.5-flash-001
GEMINI_PRO_MODEL=gemini-2.5-pro-001

# Text embedding model (768 dimensions)
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSIONS=768

# ─── Graph Database Backend ──────────────────────────────────────────────────

# Primary backend: "spanner" (default) or "neo4j"
GRAPH_BACKEND=spanner

# Neo4j connection (only needed if GRAPH_BACKEND=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# FalkorDB connection (optional alternative)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# ─── API Configuration ───────────────────────────────────────────────────────

# Admin API key for bootstrapping (auto-generated in production via Secret Manager)
# Run: make create-admin-key to generate
ADMIN_API_KEY=change-this-to-a-secure-random-key

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://app.dialectica.tacitus.ai

# API rate limits (requests per minute per key)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_EXTRACT=10
RATE_LIMIT_REASON=20

# ─── Environment & Auth Hardening ────────────────────────────────────────────

# Environment: "development" or "production"
# In production, ADMIN_API_KEY must be set (no default dev key allowed)
ENVIRONMENT=development

# Rate limit backend: "memory" (single process, dev) or "redis" (production)
RATE_LIMIT_BACKEND=memory

# Redis URL (required when RATE_LIMIT_BACKEND=redis)
REDIS_URL=redis://localhost:6379

# Multi-key auth: JSON array of API key definitions
# Each entry: {"key": "...", "level": "admin|standard|readonly", "tenant_id": "...", "expires_at": null|"ISO-date"}
# Example:
# API_KEYS_JSON=[{"key":"sk-admin-xxx","level":"admin","tenant_id":"admin"},{"key":"sk-read-yyy","level":"readonly","tenant_id":"tenant-1","expires_at":"2027-01-01T00:00:00Z"}]
API_KEYS_JSON=[]

# ─── Web Application ────────────────────────────────────────────────────────

# API URL for the web app to connect to
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Google Cloud Pub/Sub ────────────────────────────────────────────────────

# Topic for async extraction jobs
PUBSUB_EXTRACTION_TOPIC=dialectica-extraction-requests
PUBSUB_EXTRACTION_SUBSCRIPTION=dialectica-extraction-worker
PUBSUB_DLQ_TOPIC=dialectica-extraction-dlq

# ─── Google Cloud Storage ───────────────────────────────────────────────────

# Bucket for uploaded documents
GCS_DOCUMENTS_BUCKET=${GCP_PROJECT_ID}-dialectica-documents

# ─── GLiNER Configuration ───────────────────────────────────────────────────

# GLiNER model for pre-filtering (downloads on first use, ~500MB)
GLINER_MODEL=gliner-community/gliner_medium-v2.5
GLINER_THRESHOLD=0.4
GLINER_ENABLED=true

# ─── Extraction Configuration ───────────────────────────────────────────────

# Default ontology tier: essential, standard, full
DEFAULT_EXTRACTION_TIER=standard

# Maximum document size for extraction (bytes)
MAX_DOCUMENT_SIZE=10485760

# Chunk size for large document processing
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Maximum extraction retries on validation failure
MAX_EXTRACTION_RETRIES=3
